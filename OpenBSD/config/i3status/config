# i3status configuration file.
# see "man i3status" for documentation.

# It is important that this file is edited as UTF-8.
# The following line should contain a sharp s:
# ß
# If the above line is not correctly displayed, fix your editor first!

general {
        output_format = "i3bar"
        colors = true
        interval = 1
}

order += "ipv6"
order += "wireless _first_"
order += "ethernet _first_"
order += "cpu_usage"
order += "load"
order += "disk /"
order += "disk /home"
order += "volume master"
order += "tztime local"

cpu_usage {
         format = "CPU %usage"
}

wireless _first_ {
        format_up = "iwx0: (%quality at %essid) %ip"
        format_down = "W: down"
}

ethernet _first_ {
        format_up = "re0: %ip (%speed)"
        format_down = "E: down"
}

disk "/" {
        format = "/ %percentage_used"
}

disk "/home" {
	format = "/home %percentage_used"
}

volume master {
	format = "VOL %volume"
}

load {
        format = "LOA %1min"
}

tztime local {
        format = "%d-%m-%Y %H:%M:%S"
}
