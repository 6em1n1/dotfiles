# i3status configuration file.
# see "man i3status" for documentation.

# It is important that this file is edited as UTF-8.
# The following line should contain a sharp s:
# ß
# If the above line is not correctly displayed, fix your editor first!

general {
        output_format = "i3bar"
        colors = true
        color_good = "#b9f27c"
        color_degraded = "#ff9e64"
        color_bad = "#ff7a93"
        interval = 1
}

order += "ipv6"
order += "wireless _first_"
# order += "ethernet _first_"
order += "cpu_usage"
order += "load"
# order += "disk /"
# order += "disk /home"
order += "volume master"
order += "battery all"
order += "tztime local"

cpu_usage {
         format = "CPU %usage"
}

ipv6 {
         format_up = "wg0: %ip"
         format_down = "wg0: down"
}

wireless _first_ {
        format_up = "athn0: (%quality at %essid) %ip"
        format_down = "athn0: down"
}

# ethernet _first_ {
#        format_up = "re0: %ip (%speed)"
#        format_down = "E: down"
# }

# disk "/" {
#        format = "/ %percentage_used"
# }

# disk "/home" {
#        format = "/home %percentage_used"
# }

volume master {
	format = "VOL %volume"
}

load {
        format = "LOA %1min"
}

battery all {
        format = "%status %percentage"
        threshold_type = "percentage"
        low_threshold = 20
}

tztime local {
        format = "%d-%m-%Y %H:%M:%S"
}
